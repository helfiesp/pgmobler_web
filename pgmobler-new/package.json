{
  "name": "pgmobler-web",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "remix vite:build",
    "dev": "remix vite:dev",
    "start": "wrangler pages dev ./build/client",
    "deploy": "wrangler pages deploy ./build/client",
    "typecheck": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply pgmobler-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply pgmobler-db --remote",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@remix-run/cloudflare": "^2.15.0",
    "@remix-run/cloudflare-pages": "^2.15.0",
    "@remix-run/react": "^2.15.0",
    "drizzle-orm": "^0.36.0",
    "isbot": "^5.1.0",
    "nanoid": "^5.0.0",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "@remix-run/dev": "^2.15.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "drizzle-kit": "^0.28.0",
    "pg": "^8.20.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^5.1.0",
    "wrangler": "^3.99.0"
  }
}
